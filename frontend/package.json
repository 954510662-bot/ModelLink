{
  "name": "model-link-gui",
  "version": "0.1.0",
  "description": "ModelLink Desktop GUI Application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tanstack/react-query": "^5.59.0",
    "recharts": "^2.12.7",
    "react-hot-toast": "^2.4.1",
    "zustand": "^5.0.0",
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "tailwindcss": "^3.4.14",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "daisyui": "^4.12.14",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.modellink.app",
    "productName": "ModelLink",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "msi"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
